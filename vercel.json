{
  "rewrites": [
    {
      "source": "/api/create-checkout-session",
      "destination": "/api/stripe/create-checkout-session"
    },
    {
      "source": "/api/stripe-webhook",
      "destination": "/api/stripe/webhook"
    },
    {
      "source": "/api/verify-entitlement",
      "destination": "/api/entitlements/verify"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
