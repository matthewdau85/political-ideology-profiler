# Vite client variables (must start with VITE_)
# IMPORTANT: Vite variables are injected at build time.
# After changing these in Vercel, trigger a new deployment.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
VITE_POSTHOG_KEY=phc_xxx
VITE_PLAUSIBLE_DOMAIN=your-domain.com
VITE_ADSENSE_CLIENT_ID=ca-pub-XXXXX
VITE_TURNSTILE_SITE_KEY=0x4AAAAA_placeholder

# Server-only variables for Vercel Functions (never exposed to browser code)
APP_ORIGIN=https://your-domain.com
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_DEEP_ANALYSIS=price_xxx
STRIPE_PRICE_REPORT=price_xxx
STRIPE_PRICE_COUNTRY_COMPARE=price_xxx
# Legacy alias (optional during migration): STRIPE_PRICE_COUNTRY_COMPARISON=price_xxx
STRIPE_PRICE_FRIEND_COMPARE=price_xxx
# Legacy alias (optional during migration): STRIPE_PRICE_FRIEND_COMPARISON=price_xxx
STRIPE_PRICE_PREMIUM_MEMBERSHIP=price_xxx
# Legacy alias (optional during migration): STRIPE_PRICE_MEMBERSHIP=price_xxx

UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

RESEND_API_KEY=re_xxx

ADMIN_API_TOKEN=replace-with-long-random-owner-token
TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000AA
